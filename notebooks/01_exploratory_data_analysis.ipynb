# SECTION: Exploratory Data Analysis (EDA)
# DESCRIPTION: Visualizes target distributions, feature correlations, and 
#              PCA separations using sampled data to prevent memory crashes.
# =============================================================================

import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import os

# Set the visual style for all plots
sns.set_theme(style="whitegrid", palette="muted")

# 1. Load the data (We use relative paths to look inside the data folder)
print("Loading data...")
interim_path = "../data/interim/cleaned_data.csv"
processed_path = "../data/processed/final_data.csv"

# Load the data
df_clean = pd.read_csv(interim_path)
df_pca = pd.read_csv(processed_path)

print("Data loaded successfully!")

# =============================================================================
# CHART 1: Distribution of Target Variable
# =============================================================================
plt.figure(figsize=(10,
5))
ax = sns.countplot(data=df_clean, x='label')
plt.title('Distribution of Target Variable (Label)', fontsize=14, fontweight='bold')
plt.xlabel('Label Class', fontsize=12)
plt.ylabel('Count', fontsize=12)

# Add counts on top of the bars for clarity
for p in ax.patches:
    ax.annotate(f'{int(p.get_height())
}', (p.get_x() + p.get_width() / 2., p.get_height()),
                ha='center', va='bottom', fontsize=9, color='black', xytext=(0,
5),
                textcoords='offset points')

plt.xticks(rotation=45, ha='right')
plt.tight_layout()
plt.show()

# =============================================================================
# CHART 2: Correlation Heatmap (Sampled for speed)
# =============================================================================
print("Generating correlation heatmap...")
# We take a random sample of 50,
000 rows so the heatmap calculates instantly
df_sample = df_clean.sample(n=50000, random_state=42)

# Select only numeric columns for correlation
numeric_cols = df_sample.select_dtypes(include='number')

plt.figure(figsize=(12,
8))
corr_matrix = numeric_cols.corr()

sns.heatmap(corr_matrix, annot=False, cmap='coolwarm', linewidths=0, vmin=-1, vmax=1)
plt.title('Correlation Heatmap of Features (Sampled)', fontsize=16, fontweight='bold')
plt.show()

# =============================================================================
# CHART 3: PCA Scatter Plot (PC1 vs PC2)
# =============================================================================
print("Generating PCA scatter plot...")
# FIX: Randomly sample 10,
000 rows so the browser doesn't crash!
pca_sample = df_pca.sample(n=10000, random_state=42)

plt.figure(figsize=(10,
7))
sns.scatterplot(
    data=pca_sample,
    x='PC1',
    y='PC2',
    hue='label',
    palette='viridis',
    alpha=0.7,
    s=60 # dot size
)

plt.title('Scatter Plot: Principal Component 1 vs 2 (Sampled 10k points)', fontsize=14, fontweight='bold')
plt.xlabel('Principal Component 1 (PC1)', fontsize=12)
plt.ylabel('Principal Component 2 (PC2)', fontsize=12)

# Move the legend outside the plot so it doesn't cover data points
plt.legend(title='Label', bbox_to_anchor=(1.05,
1), loc='upper left')
plt.tight_layout()
plt.show()
